{
  "name": "ariscode-cli",
  "version": "2.0.0",
  "description": "CLI generador de proyectos y componentes con plantillas predefinidas para React, NestJS y más",
  "main": "dist/index.js",
  "bin": {
    "aris": "dist/index.js"
  },
  "files": [
    "dist/",
    "patterns/",
    "templates/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:create": "vitest run tests/create.test.ts",
    "ci": "npm run build && npm test",
    "build:pkg": "npm run build && pkg -t node18-linux-x64,node18-win-x64 --out-path release dist/index.js",
    "release:gh": "bash scripts/create_release.sh",
    "release:gh-windows": "powershell -ExecutionPolicy Bypass -File scripts/create_release.ps1"
  },
  "keywords": [
    "cli",
    "generator",
    "code-generator",
    "templates",
    "scaffolding",
    "react",
    "nestjs",
    "boilerplate",
    "typescript",
    "handlebars"
  ],
  "author": "Naren15022005 <naren15022005@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Naren15022005/ariscode.git"
  },
  "bugs": {
    "url": "https://github.com/Naren15022005/ariscode/issues"
  },
  "homepage": "https://github.com/Naren15022005/ariscode#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "cli-table3": "^0.6.0",
    "commander": "^10.0.0",
    "handlebars": "^4.7.7",
    "prompts": "^2.4.2",
    "ts-morph": "^17.0.1",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "axios": "^1.6.0",
    "tar": "^6.2.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^8.2.0"
  },
  "devDependencies": {
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "@types/node": "^18.0.0",
    "@types/commander": "^2.12.2",
    "@types/tar": "^6.1.0",
    "@types/prompts": "^2.4.9",
    "rimraf": "^5.0.0",
    "pnpm": "^8.0.0",
    "vitest": "^1.3.0",
    "pkg": "^5.8.1"
  }

  ,
  "pkg": {
    "scripts": [],
    "assets": []
  }
}
