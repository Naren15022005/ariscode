{
  "name": "ariscode-cli",
  "version": "1.1.0",
  "description": "CLI de Aris Code (scaffold)",
  "main": "dist/index.js",
  "bin": {
    "aris": "dist/index.js"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:create": "vitest run tests/create.test.ts",
    "ci": "npm run build && npm test",
    "build:pkg": "npm run build && pkg -t node18-linux-x64,node18-win-x64 --out-path release dist/index.js",
    "release:gh": "bash scripts/create_release.sh",
    "release:gh-windows": "powershell -ExecutionPolicy Bypass -File scripts/create_release.ps1"
  },
  "keywords": ["aris","cli","code"],
  "author": "Alfonsito",
  "license": "MIT",
  "dependencies": {
    
    "cli-table3": "^0.6.0",
    "commander": "^10.0.0",
    "handlebars": "^4.7.7",
    "prompts": "^2.4.2",
    "ts-morph": "^17.0.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^8.2.0"
  },
  "devDependencies": {
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "@types/node": "^18.0.0",
    "@types/commander": "^2.12.2",
    "rimraf": "^5.0.0",
    "pnpm": "^8.0.0",
    "vitest": "^1.3.0",
    "pkg": "^5.8.1"
  }

  ,
  "pkg": {
    "scripts": [],
    "assets": []
  }
}
